# =============================================================================
# LORNEWS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# --- Required ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production              # Generate: openssl rand -hex 64
POSTGRES_PASSWORD=lornews                       # Database password (Render will provide)
DATABASE_URL=postgresql+asyncpg://lornews:PASSWORD@HOST:5432/lornews

# --- Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://lornews-backend.onrender.com  # Backend URL
# When running locally: http://localhost:8000

# --- API ───────────────────────────────────────────────────────────────────
API_DEBUG=false
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=https://lornews-frontend.onrender.com
TRUSTED_HOSTS=lornews-backend.onrender.com,*.onrender.com

# --- LLM ───────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                              # openai | anthropic | google | ollama
LLM_API_KEY=sk-...                               # Your OpenAI API key
LLM_MODEL=gpt-4o

# --- Redis (Upstash) ──────────────────────────────────────────────────────
# 1. Sign up at https://console.upstash.com
# 2. Create a free Redis database (10MB)
# 3. Copy the REST URL
REDIS_URL=redis://default:PASSWORD@RANDOM.upstash.io:6379

# --- Qdrant Cloud ──────────────────────────────────────────────────────────
# 1. Sign up at https://cloud.qdrant.io
# 2. Create a free cluster (1GB)
# 3. Copy the cluster URL
QDRANT_URL=https://RANDOM-0000.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=  # Optional: set if your cluster requires authentication

# --- Performance ───────────────────────────────────────────────────────────
ENABLE_COMPRESSION=true
ENABLE_METRICS=true
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
CACHE_TTL_SECONDS=3600

# --- Telegram (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
