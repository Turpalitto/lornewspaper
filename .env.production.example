# =============================================================================
# LORNEWS — Production Environment Variables
# Copy this to .env on your Render dashboard
# =============================================================================

# --- Security ──────────────────────────────────────────────────────────────
# Generate a random 64-character hex string:
#   Linux/macOS: openssl rand -hex 64
#   Windows: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=__GENERATE_A_RANDOM_64_CHAR_HEX_STRING__
API_DEBUG=false
TRUSTED_HOSTS=lornews-backend.onrender.com,*.onrender.com
API_CORS_ORIGINS=https://lornews-frontend.onrender.com

# --- LLM Provider ──────────────────────────────────────────────────────────
# Get your API key from: https://platform.openai.com/api-keys
LLM_API_KEY=sk-proj-__YOUR_OPENAI_API_KEY_HERE__
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini  # Cheaper than gpt-4o, good for summaries

# --- PostgreSQL (set automatically by Render) ──────────────────────────────
# You do NOT need to set this manually.
# Render will inject DATABASE_URL automatically from the PostgreSQL service.
# DATABASE_URL=postgresql+asyncpg://lornews:...@...:5432/lornews

# --- Redis (Upstash) ──────────────────────────────────────────────────────
# Sign up: https://console.upstash.com
# Create: Serverless Redis (free tier: 10MB)
# Copy the Redis URL (NOT the REST URL) from Upstash console
REDIS_URL=redis://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_ENDPOINT.upstash.io:6379

# --- Qdrant Cloud ──────────────────────────────────────────────────────────
# Sign up: https://cloud.qdrant.io
# Create: Free cluster (1GB)
# Copy the cluster URL
QDRANT_URL=https://YOUR_CLUSTER_ID-0000.us-east-1-0.aws.cloud.qdrant.io:6333

# --- Performance ──────────────────────────────────────────────────────────
ENABLE_COMPRESSION=true
ENABLE_METRICS=true
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
CACHE_TTL_SECONDS=3600
CONNECTION_POOL_MIN=2
CONNECTION_POOL_MAX=10

# --- Telegram (optional) ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
# Get the bot token
# Get your channel/chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
